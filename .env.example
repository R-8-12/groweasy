# ─────────────────────────────────────────────────────────────
# GrowEasy AI CSV Importer — Environment Variables
# Copy this file to .env and fill in the values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── LLM API Key ───────────────────────────────────────────────
# Required. Your OpenAI API key (starts with "sk-").
# Obtain one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Backend ───────────────────────────────────────────────────
# Port the backend Express server listens on inside the container.
# Change only if you need to remap the host port in docker-compose.yml.
PORT=4000

# ── CORS origin consumed by the backend ───────────────────────
# The URL of the frontend as seen by browser clients.
# Used to set Access-Control-Allow-Origin on the backend.
# For local development the default matches the frontend container port.
FRONTEND_ORIGIN=http://localhost:3000

# ── Backend URL consumed by the frontend ──────────────────────
# Set automatically to http://backend:4000 inside Docker Compose
# so that the frontend container can reach the backend service.
# Override here only if you are running outside Docker Compose.
# NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
